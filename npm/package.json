{
  "name": "this.me",
  "version": "3.2.2",
  "type": "module",
  "main": "./dist/me.cjs",
  "module": "./dist/me.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": "./dist/me.es.js",
      "import": "./dist/me.es.js",
      "require": "./dist/me.cjs"
    }
  },
  "scripts": {
    "dev": "vite --config vite.config.ts",
    "build": "vite build --config vite.config.ts",
    "preview": "vite preview --config vite.config.ts",
    "test:ts": "tsc --noEmit",
    "test:umd": "node tests/Builds/umd.test.cjs",
    "test:prebuild": "node tests/pre-build.test.mjs",
    "test:contracts": "node tests/contracts/dsl.contract.test.mjs",
    "prepublishOnly": "npm run build",
    "docs:api": "typedoc",
    "docs:api:watch": "typedoc --watch",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "docs:publish": "npm run docs:build && rm -rf ../docs && mkdir -p ../docs && cp -R docs/.vitepress/dist/* ../docs/ && touch ../docs/.nojekyll"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "js-sha3": "^0.9.3"
  },
  "devDependencies": {
    "@types/node": "^24.10.13",
    "typedoc": "^0.28.16",
    "typedoc-plugin-markdown": "^4.9.0",
    "vite": "^7.0.6",
    "vite-plugin-dts": "^4.5.4",
    "vitepress": "^1.6.4"
  },
  "description": ".me is your identity trust through cryptographic signatures.",
  "keywords": [
    "this.me",
    "semantic kernel",
    "identity runtime",
    "deterministic identity",
    "cryptographic signatures",
    "secret scopes",
    "encrypted memory",
    "semantic graph",
    "deterministic inference",
    "decentralized authentication",
    "inverted dependency index",
    "contextual reasoning",
    "secure data storage",
    "personalized AI",
    "hermetic rpn evaluator",
    "functional reactive logic",
    "content-addressable dependency graph"
  ],
  "license": "MIT",
  "author": "suiGn"
}
